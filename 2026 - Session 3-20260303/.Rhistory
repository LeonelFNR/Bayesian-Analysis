## Data
n <- 40
y_c <- 24
y_e <- 30
## Likelihood distributions
likelihood_c <- dbinom(y_c, n, p)
likelihood_e <- dbinom(y_e, n, p)
ggplot(df, aes(p, density, color = treatment, linetype = treatment)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "red"), labels = c("Conventional", "Experimental")) +
scale_linetype_manual(values = c("solid", "dashed"), labels = c("Conventional", "Experimental")) +
theme_minimal() +
theme(legend.title = element_blank())
## Likelihood distributions
likelihood_c <- dbinom(y_c, n, p)
likelihood_e <- dbinom(y_e, n, p)
## Posterior distributions
posterior_c <- dbeta(p, prior_par_c[1] + y_c, prior_par_c[2] + n - y_c) # looking at wikipedia formula
posterior_e <- dbeta(p, prior_par_e[1] + y_e, prior_par_e[2] + n - y_e)
#Plots
df <- tibble(p, prior_c, likelihood_c, posterior_c, prior_e, likelihood_e, posterior_e) %>%
pivot_longer(cols = c(prior_c, likelihood_c, posterior_c), names_to = "type", values_to = "density") %>%
pivot_longer(cols = c(prior_e, likelihood_e, posterior_e), names_to = "type_e", values_to = "density_e") %>%
filter((type == "prior_c" & type_e == "prior_e") | (type == "likelihood_c" & type_e == "likelihood_e") | (type == "posterior_c" & type_e == "posterior_e")) %>%
mutate(treatment = case_when(type == "prior_c" ~ "Conventional",
type == "likelihood_c" ~ "Conventional",
type == "posterior_c" ~ "Conventional",
type == "prior_e" ~ "Experimental",
type == "likelihood_e" ~ "Experimental",
type == "posterior_e" ~ "Experimental"),
distribution = case_when(type %in% c("prior_c", "prior_e") ~ "Prior",
type %in% c("likelihood_c", "likelihood_e") ~ "Likelihood",
type %in% c("posterior_c", "posterior_e") ~ "Posterior"))
ggplot(df, aes(p, density, color = treatment, linetype = distribution))
#Plots
df <- tibble(p, prior_c, likelihood_c, posterior_c, prior_e, likelihood_e, posterior_e) %>%
pivot_longer(cols = c(prior_c, likelihood_c, posterior_c), names_to = "type", values_to = "density") %>%
pivot_longer(cols = c(prior_e, likelihood_e, posterior_e), names_to = "type_e", values_to = "density_e")
ggplot(df, aes(p)) +
geom_line(aes(y = density, color = type, linetype = type))
#Plots
df <- tibble(p, prior_c, likelihood_c, posterior_c, prior_e, likelihood_e, posterior_e) %>%
pivot_longer(cols = c(prior_c, likelihood_c, posterior_c), names_to = "type", values_to = "density") %>%
pivot_longer(cols = c(prior_e, likelihood_e, posterior_e), names_to = "type_e", values_to = "density_e")
ggplot(df, aes(p)) +
geom_line(aes(y = density, color = type, linetype = type))
ggplot(df, aes(p, density, color = type, linetype = type)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density")
ggplot(df, aes(p, density_e, color = type_e, linetype = type_e)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density")
ggplot(df, aes(p, density, color = type, linetype = type)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "blue", "blue", "red", "red", "red"),
labels = c("Prior (Conventional)", "Likelihood (Conventional)", "Posterior (Conventional)",
"Prior (Experimental)", "Likelihood (Experimental)", "Posterior (Experimental)")) +
scale_linetype_manual(values = c("solid", "dashed", "dotted", "solid", "dashed", "dotted"),
labels = c("Prior (Conventional)", "Likelihood (Conventional)", "Posterior (Conventional)",
"Prior (Experimental)", "Likelihood (Experimental)", "Posterior (Experimental)")) +
theme_minimal() +
theme(legend.title = element_blank())
# plot both treatments in the same graph
ggplot(df, aes(p)) +
geom_line(aes(y = density, color = type, linetype = type)) +
geom_line(aes(y = density_e, color = type_e, linetype = type_e)) +
labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "red", "blue", "red"), labels = c("Prior (Conventional)", "Likelihood (Conventional)", "Posterior (Conventional)", "Prior (Experimental)", "Likelihood (Experimental)", "Posterior (Experimental)")) +
scale_linetype_manual(values = c("solid", "dashed", "dotted", "solid", "dashed", "dotted"), labels = c("Prior (Conventional)", "Likelihood (Conventional)", "Posterior (Conventional)", "Prior (Experimental)", "Likelihood (Experimental)", "Posterior (Experimental)")) +
theme_minimal() +
theme(legend.title = element_blank())
ggplot(df) +
geom_line(aes(x = p, y = prior_c, linetype = "c", col = "1")) +
geom_line(aes(x = p, y = prior_e, linetype = "e", col = "1")) +
geom_line(aes(x = p, y = likelihood_c, linetype = "c", col = "2")) +
geom_line(aes(x = p, y = likelihood_e, linetype = "e", col = "2")) +
geom_line(aes(x = p, y = posterior_c, linetype = "c", col = "3")) +
geom_line(aes(x = p, y = posterior_e, linetype = "e", col = "3")) +
ggtitle("Prior distribution") +
ylab("density") +
scale_linetype_manual(name = "Treatment",
values = 1:2, labels = c("Conventional", "Experimental")) +
scale_color_manual(name = "Distribution",
values = 1:3, labels = c("Prior", "Likelihood", "Posterior"))
# Plot prior comparison
df <- df %>%
mutate(likelihood_c = std_dist(likelihood_c, delta_p),
likelihood_e = std_dist(likelihood_e, delta_p),
product_c = prior_c * likelihood_c,
product_e = prior_e * likelihood_e,
posterior_c = std_dist(product_c, delta_p),
posterior_e = std_dist(product_e, delta_p))
ggplot(df, aes(p, density, color = treatment, linetype = treatment)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "red"), labels = c("Conventional", "Experimental")) +
scale_linetype_manual(values = c("solid", "dashed"), labels = c("Conventional", "Experimental")) +
theme_minimal() +
theme(legend.title = element_blank())
# function to standarize
std_dist <- function(x, delta) {
x / (sum(x) * delta)
}
# Plot prior comparison
df <- df %>%
mutate(likelihood_c = std_dist(likelihood_c, delta_p),
likelihood_e = std_dist(likelihood_e, delta_p),
product_c = prior_c * likelihood_c,
product_e = prior_e * likelihood_e,
posterior_c = std_dist(product_c, delta_p),
posterior_e = std_dist(product_e, delta_p))
ggplot(df, aes(p, density, color = treatment, linetype = treatment)) +
geom_line() +  labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "red"), labels = c("Conventional", "Experimental")) +
scale_linetype_manual(values = c("solid", "dashed"), labels = c("Conventional", "Experimental")) +
theme_minimal() +
theme(legend.title = element_blank())
