## Prior distributions
delta_p <- 0.01
p <- seq(0, 1, delta_p)
# Conventional prior: 0.4 < p < 0.8
prior_par_c <- c(alpha = 3, beta = 2)
prior_c <- dbeta(p, prior_par_c[1], prior_par_c[2])
# Experimental prior: 0.6 < p < 0.9
prior_par_e <- c(alpha = 11/2, beta = 11/6)
# Plot prior comparison
df <- tibble(p, prior_c, prior_e) %>%
pivot_longer(cols = c(prior_c, prior_e), names_to = "treatment", values_to = "density")
library(tibble)
# Plot prior comparison
df <- tibble(p, prior_c, prior_e) %>%
pivot_longer(cols = c(prior_c, prior_e), names_to = "treatment", values_to = "density")
install.packages("tidyr")   # solo la primera vez
library(tidyr)
# Plot prior comparison
df <- tibble(p, prior_c, prior_e) %>%
pivot_longer(cols = c(prior_c, prior_e), names_to = "treatment", values_to = "density")
prior_e <- dbeta(p, prior_par_e[1], prior_par_e[2])
# Plot prior comparison
df <- tibble(p, prior_c, prior_e) %>%
pivot_longer(cols = c(prior_c, prior_e), names_to = "treatment", values_to = "density")
ggplot(df, aes(p, density, color = treatment, linetype = treatment)) +
geom_line() +
labs(x = "Probability of improvement", y = "Density") +
scale_color_manual(values = c("blue", "red"), labels = c("Conventional", "Experimental")) +
scale_linetype_manual(values = c("dashed", "solid"), labels = c("Conventional", "Experimental")) +
theme_minimal() +
theme(legend.title = element_blank())
