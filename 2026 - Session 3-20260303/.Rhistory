## Likelihood distributions
likelihood_c <- dbinom(y_c, n, p)
likelihood_e <- dbinom(y_e, n, p)
## Posterior distributions
posterior_c <- dbeta(p, prior_par_c[1] + y_c, prior_par_c[2] + n - y_c) # looking at wikipedia formula
posterior_e <- dbeta(p, prior_par_e[1] + y_e, prior_par_e[2] + n - y_e)
#Plots
df <- tibble(p, prior_c, likelihood_c, posterior_c, prior_e, likelihood_e, posterior_e) %>%
pivot_longer(cols = c(prior_c, likelihood_c, posterior_c), names_to = "type", values_to = "density") %>%
pivot_longer(cols = c(prior_e, likelihood_e, posterior_e), names_to = "type_e", values_to = "density_e") %>%
filter((type == "prior_c" & type_e == "prior_e") | (type == "likelihood_c" & type_e == "likelihood_e") | (type == "posterior_c" & type_e == "posterior_e")) %>%
mutate(treatment = case_when(type == "prior_c" ~ "Conventional",
type == "likelihood_c" ~ "Conventional",
type == "posterior_c" ~ "Conventional",
type == "prior_e" ~ "Experimental",
type == "likelihood_e" ~ "Experimental",
type == "posterior_e" ~ "Experimental"),
distribution = case_when(type %in% c("prior_c", "prior_e") ~ "Prior",
type %in% c("likelihood_c", "likelihood_e") ~ "Likelihood",
type %in% c("posterior_c", "posterior_e") ~ "Posterior"))
ggplot(df, aes(p, density, color = treatment, linetype = distribution))
#Plots
