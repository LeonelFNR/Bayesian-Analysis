for (s in 1:n_sims) {
mu <- post$alpha[s, group_train] + as.vector(X_train %*% post$beta[s, ])
y_pred_log_sims[s, ] <- rnorm(N_train, mean = mu, sd = post$sigma[s])
}
# Media posterior en escala log
